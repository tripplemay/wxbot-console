# Bot Platform 运营控制台 —— 环境变量
# 复制为 .env.local 并按实际填写(.env.local 已被 gitignore)

# 平台 API 地址(wxbot 的 `npm run platform:serve`,默认端口 8787)
PLATFORM_API_URL=http://localhost:8787

# 平台 admin API key —— BFF 服务端持有,绝不下发浏览器。
# 必须与平台启动时的 BOT_PLATFORM_API_KEY 一致,且具备 admin:read/admin:write 权限。
PLATFORM_API_KEY=dev-local-admin-key

# 控制台会话 JWT 签名密钥(HS256)。生产请用高强度随机值:
#   openssl rand -base64 48
CONSOLE_JWT_SECRET=replace-me-with-a-long-random-secret
